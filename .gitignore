# =============================================================================
# AWS Multi-Region Stack - .gitignore
# =============================================================================

# =============================================================================
# Terraform
# =============================================================================
.terraform/
.terraform.lock.hcl
*.tfstate
*.tfstate.*
*.tfvars
!*.tfvars.example
*.tfvars.json
.terraform.tfstate.lock.info
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# Terraform plan files
*.tfplan
tfplan
tfplan.out

# =============================================================================
# Environment Variables
# =============================================================================
.env
.env.*
!.env.example
.envrc

# =============================================================================
# Node.js
# =============================================================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpm-store/

# Package manager locks (optional - uncomment if you want to track them)
# package-lock.json
# yarn.lock
# pnpm-lock.yaml

# =============================================================================
# TypeScript
# =============================================================================
dist/
build/
out/
*.tsbuildinfo

# =============================================================================
# Testing
# =============================================================================
coverage/
*.lcov
.nyc_output/
tests/load/results/*.json
tests/load/results/*.html

# Go test cache
go.sum

# =============================================================================
# IDE & Editors
# =============================================================================
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
.idea/
*.swp
*.swo
*.swn
*~
*.sublime-project
*.sublime-workspace

# =============================================================================
# Operating System
# =============================================================================
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# =============================================================================
# LocalStack
# =============================================================================
localstack-data/
localstack/*/volume/
.localstack/
localstack/**/data/

# =============================================================================
# Docker
# =============================================================================
docker-compose.override.yml
docker-compose.local.yml
.docker/

# =============================================================================
# Logs
# =============================================================================
*.log
logs/
*.log.*

# =============================================================================
# Secrets & Credentials (NEVER commit these)
# =============================================================================
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
credentials.json
secrets.json
service-account.json
*-credentials.json
*-secrets.json
id_rsa*
id_ed25519*
id_ecdsa*
id_dsa*

# AWS
.aws/
aws-credentials
credentials

# =============================================================================
# Lambda & Deployment Packages
# =============================================================================
*.zip
lambda-packages/
deployment-packages/

# =============================================================================
# Temporary Files
# =============================================================================
tmp/
temp/
*.tmp
*.temp
*.bak
*.backup

# =============================================================================
# Cache
# =============================================================================
.cache/
.parcel-cache/
.eslintcache
.stylelintcache
.prettiercache

# =============================================================================
# Misc
# =============================================================================
*.orig
*.rej
*.patch
.history/

# =============================================================================
# Application
# =============================================================================
NODE_ENV=development
PORT=3000
PROJECT_NAME=blueprint

# =============================================================================
# Region
# =============================================================================
AWS_REGION=us-east-1
REGION_KEY=us_east_1
IS_PRIMARY_REGION=true
REGION_TIER=primary

# =============================================================================
# Database (PostgreSQL / Aurora)
# =============================================================================
DATABASE_HOST=localhost
DATABASE_PORT=5433
DATABASE_NAME=app
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
# DATABASE_URL=postgresql://postgres:postgres@localhost:5433/app
# DATABASE_READ_HOST=localhost

# =============================================================================
# Redis (ElastiCache)
# =============================================================================
REDIS_HOST=localhost
REDIS_PORT=6380
# REDIS_PASSWORD=

# =============================================================================
# DynamoDB
# =============================================================================
# DYNAMODB_ORDERS_TABLE=blueprint-dev-orders

# =============================================================================
# Authentication
# =============================================================================
# API_KEY=your-api-key-here

# =============================================================================
# AWS Services (SQS / SNS)
# =============================================================================
# SQS_ORDER_QUEUE_URL=http://localhost:4566/000000000000/blueprint-dev-us-east-1-order-processing
# SQS_NOTIFICATION_QUEUE_URL=http://localhost:4566/000000000000/blueprint-dev-us-east-1-notification
# SQS_DLQ_URL=http://localhost:4566/000000000000/blueprint-dev-us-east-1-dlq
# SNS_ORDER_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:blueprint-dev-us-east-1-order-events
# SNS_NOTIFICATION_TOPIC_ARN=arn:aws:sns:us-east-1:000000000000:blueprint-dev-us-east-1-notifications

# =============================================================================
# LocalStack
# =============================================================================
USE_LOCALSTACK=true
LOCALSTACK_ENDPOINT=http://localhost:4566

# =============================================================================
# CORS (comma-separated origins, only used in production)
# =============================================================================
# CORS_ALLOWED_ORIGINS=https://app.example.com,https://admin.example.com

# =============================================================================
# Observability (OpenTelemetry)
# =============================================================================
OTEL_SERVICE_NAME=blueprint-app
# OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318

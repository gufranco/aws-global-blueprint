{
  "name": "multiregion-app",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-region Node.js application with ECS Fargate, SQS, SNS, and Lambda",
  "type": "module",
  "scripts": {
    "build": "pnpm -r build",
    "dev": "pnpm -r --parallel dev",
    "test": "pnpm -r test",
    "test:unit": "pnpm -r test:unit",
    "test:integration": "pnpm -r test:integration",
    "test:e2e": "vitest run --config vitest.e2e.config.ts",
    "test:ci": "pnpm -r test:ci",
    "lint": "pnpm -r lint",
    "lint:fix": "pnpm -r lint:fix",
    "typecheck": "pnpm -r typecheck",
    "clean": "pnpm -r clean",
    "db:migrate": "cd api && pnpm db:migrate",
    "db:seed": "cd api && pnpm db:seed",
    "docker:build": "docker build -t multiregion-api ./api && docker build -t multiregion-worker ./worker"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^1.0.0",
    "eslint": "^8.56.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  },
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=8.0.0"
  },
  "packageManager": "pnpm@8.15.0"
}
